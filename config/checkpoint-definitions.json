{
  "checkpoints": [
    {
      "id": 1,
      "name": "Spike Document",
      "required": true,
      "checklist": [
        "Problem statement is clear and unambiguous",
        "All clarifying questions answered",
        "Modules identified and scoped",
        "Technical concerns flagged",
        "Success criteria defined"
      ]
    },
    {
      "id": 2,
      "name": "Task Breakdown",
      "required": true,
      "checklist": [
        "Tasks are granular and atomic",
        "Dependencies clearly mapped",
        "Sub-checkpoints identified",
        "Effort estimates reasonable"
      ]
    },
    {
      "id": 3,
      "name": "Codebase Analysis",
      "required": true,
      "checklist": [
        "Relevant modules analyzed",
        "Patterns documented",
        "Technical concerns identified",
        "Refactoring needs noted"
      ]
    },
    {
      "id": 4,
      "name": "Prompt Generation",
      "required": true,
      "checklist": [
        "Prompts are clear and contextual",
        "Test expectations included",
        "Edge cases mentioned",
        "Framework-specific patterns referenced"
      ]
    },
    {
      "id": 5,
      "name": "Code Execution",
      "required": false,
      "checklist": [
        "Code matches the Expected Output file list",
        "Constraints from the prompt were respected",
        "No unrelated files were modified"
      ]
    },
    {
      "id": 6,
      "name": "Test Results",
      "required": false,
      "checklist": [
        "All listed test requirements have corresponding tests",
        "All edge cases from the prompt are covered",
        "Tests pass, or a retry context was generated"
      ]
    },
    {
      "id": 7,
      "name": "Self-Verification",
      "required": true,
      "checklist": [
        "Architectural fit checked against codebase patterns",
        "Security, data integrity, and concurrency considered",
        "Performance implications considered",
        "Safe issues auto-fixed and re-tested",
        "Remaining concerns clearly flagged with recommendations"
      ]
    },
    {
      "id": 8,
      "name": "Business Logic Review",
      "required": true,
      "checklist": [
        "Code solves the original problem",
        "Business logic correct",
        "Fits existing architecture",
        "Ready for deployment"
      ]
    }
  ]
}
