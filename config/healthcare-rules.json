{
  "description": "Healthcare-specific rules for HIPAA compliance, PHI handling, and secure communication",
  "healthcare": {
    "phi_fields": [
      "phone",
      "email",
      "ssn",
      "date_of_birth",
      "address"
    ],
    "encryption": {
      "algorithm": "AES-256",
      "key_source": "ENCRYPTION_KEY_PHI",
      "always_encrypt_fields": true
    },
    "audit_logging": {
      "enabled": true,
      "log_all_phi_access": true,
      "retention_years": 6,
      "immutable": true
    },
    "compliance": {
      "hipaa_required": true,
      "pii_in_logs_forbidden": true,
      "pii_in_responses_forbidden": true,
      "auth_required_for_phi": true
    },
    "communication": {
      "sms_provider": "twilio",
      "email_provider": "sendgrid",
      "never_include_medical_details": true,
      "generic_messages_only": true
    },
    "testing": {
      "security_tests_required": true,
      "hipaa_checklist_required": true,
      "encryption_tests_required": true
    }
  }
}
